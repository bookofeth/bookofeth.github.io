<!DOCTYPE html>
<html lang="{$currentLocale ?? 'en'}">
<head>
    {include '../partials/head.latte', pageTitle: ($pageTitle ?? ''), pageDescription: ($pageDescription ?? ''), pageSlug: ($pageSlug ?? ''), pageCss: ($pageCss ?? '')}
    {block head}{/block}
</head>
<body class="{$bodyClass ?? ''}">
    <a href="#main" class="skip-link">Skip to content</a>
    {include '../partials/nav.latte'}
    {block content}{/block}
    {include '../partials/footer.latte'}
    <script defer src="/assets/js/site.js"></script>
</body>
</html>
